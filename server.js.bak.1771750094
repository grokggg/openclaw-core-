#!/usr/bin/env node
const express = require('express');
const app = express();

// 基本API路由
app.get('/health', (req, res) => {
    res.json({ 
        status: 'healthy', 
        version: '2.0.0',
        timestamp: new Date().toISOString()
    });
});

// 启动
const PORT = 3002;
app.listen(PORT, () => {
    console.log(`
╔══════════════════════════════════════════════╗
║                                              ║
║  🎉 OpenClaw AI Orchestrator 启动成功!      ║
║                                              ║
║  📊 访问: http://localhost:${PORT}           ║
║  🩺 健康: http://localhost:${PORT}/health    ║
║                                              ║
╚══════════════════════════════════════════════╝
    `);
});
